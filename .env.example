# Copy to .env and fill in values

# Database
DATABASE_URL=postgresql://netdeploy:password@localhost:5432/netdeploy

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Git config repo
GIT_REPO_PATH=/app/config_repo
GIT_REMOTE_URL=

# API
LOG_LEVEL=info
SECRET_KEY=changeme-use-a-long-random-string-in-production

# SSH defaults (override per device in DB)
SSH_USERNAME=admin
SSH_TIMEOUT=30

# Deployment
CANARY_HEALTH_WAIT_SECONDS=300

# Dashboard
NETDEPLOY_API_URL=http://localhost:8000
